<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="color-scheme" content="dark">
<meta name="supported-color-schemes" content="dark">
<meta name="theme-color" content="#0d1117">
<title>The Grapefruit League — Dynasty Auction</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0d1117; --surface: #161b22; --surface2: #1e2530; --border: #2a3441;
  --accent: #e8b84b; --green: #3fb68b; --danger: #e05555; --blue: #4a9eda;
  --text: #e6edf3; --muted: #7d8590; --subtle: #3d4b5c;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html { background: #0d1117 !important; color-scheme: dark; }
body { background: #0d1117 !important; color: var(--text); font-family: 'DM Sans', sans-serif; min-height: 100vh; }

/* HEADER */
.header { background: #161b22; border-bottom: 2px solid var(--border); padding: 0 20px; display: flex; align-items: stretch; gap: 0; position: sticky; top: 0; z-index: 50; height: 55px; }
.logo { font-family: 'Bebas Neue', sans-serif; font-size: 26px; letter-spacing: 3px; color: var(--accent); padding: 14px 20px 14px 0; border-right: 1px solid var(--border); margin-right: 4px; display: flex; align-items: center; gap: 8px; white-space: nowrap; }
.logo span { font-size: 22px; }
.tabs { display: flex; }
.tab { padding: 0 20px; font-size: 12px; font-weight: 600; cursor: pointer; border-bottom: 3px solid transparent; color: var(--muted); transition: all 0.15s; letter-spacing: 1px; text-transform: uppercase; display: flex; align-items: center; gap: 6px; }
.tab:hover { color: var(--text); }
.tab.active { color: var(--accent); border-bottom-color: var(--accent); }
.tab-badge { background: var(--surface2); border: 1px solid var(--border); border-radius: 10px; padding: 1px 7px; font-size: 10px; font-family: 'DM Mono', monospace; color: var(--muted); }
.tab.active .tab-badge { border-color: var(--accent); color: var(--accent); background: rgba(232,184,75,0.08); }

/* PANELS */
.panel { display: none; padding: 20px; max-width: 1600px; }
.panel.active { display: block; }

/* STAT CARDS */
.stat-row { display: flex; gap: 12px; margin-bottom: 18px; flex-wrap: wrap; }
.stat-card { background: #161b22; border: 1px solid var(--border); border-radius: 8px; padding: 10px 16px; display: flex; flex-direction: column; gap: 3px; min-width: 110px; }
.stat-card.highlight { border-color: var(--accent); }
.stat-label { font-size: 9px; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); font-family: 'DM Mono', monospace; }
.stat-val { font-family: 'Bebas Neue', sans-serif; font-size: 26px; letter-spacing: 1px; line-height: 1; }
.stat-val.gold { color: var(--accent); }
.stat-val.green { color: var(--green); }
.stat-val.red { color: var(--danger); }
.stat-val.blue { color: var(--blue); }

/* TOOLBAR */
.toolbar { display: flex; gap: 10px; margin-bottom: 14px; flex-wrap: wrap; align-items: center; }
.search-wrap { position: relative; }
.search-wrap input { background: var(--surface2); border: 1px solid var(--border); color: var(--text); padding: 8px 12px 8px 34px; border-radius: 6px; font-size: 13px; width: 220px; outline: none; font-family: 'DM Sans', sans-serif; }
.search-wrap input:focus { border-color: var(--accent); }
.search-wrap::before { content: '🔍'; position: absolute; left: 10px; top: 50%; transform: translateY(-50%); font-size: 12px; pointer-events: none; opacity: 0.5; }
select.fsel { background: var(--surface2); border: 1px solid var(--border); color: var(--text); padding: 8px 10px; border-radius: 6px; font-size: 13px; outline: none; cursor: pointer; font-family: 'DM Sans', sans-serif; }
select.fsel:focus { border-color: var(--accent); }
.btn { padding: 8px 16px; border-radius: 6px; border: 1px solid; font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.15s; font-family: 'DM Sans', sans-serif; letter-spacing: 0.3px; }
.btn-primary { background: var(--accent); border-color: var(--accent); color: #000; }
.btn-primary:hover { background: #f0c85a; }
.btn-ghost { background: transparent; border-color: var(--border); color: var(--muted); }
.btn-ghost:hover { border-color: var(--text); color: var(--text); }
.btn-sm { padding: 4px 10px; font-size: 11px; }
.btn-green { background: transparent; border-color: var(--green); color: var(--green); }
.btn-green:hover { background: var(--green); color: #000; }
.btn-danger { background: transparent; border-color: var(--danger); color: var(--danger); }
.btn-danger:hover { background: var(--danger); color: #fff; }
.count-pill { background: var(--surface2); border: 1px solid var(--border); color: var(--muted); padding: 4px 12px; border-radius: 20px; font-size: 11px; font-family: 'DM Mono', monospace; }

/* TABLE */
.tbl-wrap { overflow-x: auto; border: 1px solid var(--border); border-radius: 8px; }
table { width: 100%; border-collapse: collapse; font-size: 13px; }
thead { background: #1e2530; }
th { padding: 10px 12px; text-align: left; font-family: 'DM Mono', monospace; font-size: 10px; text-transform: uppercase; letter-spacing: 0.8px; color: var(--muted); white-space: nowrap; cursor: pointer; user-select: none; border-bottom: 1px solid var(--border); }
th:hover { color: var(--text); }
th.sort-asc::after { content: ' ▲'; color: var(--accent); }
th.sort-desc::after { content: ' ▼'; color: var(--accent); }
td { padding: 8px 12px; border-top: 1px solid rgba(42,52,65,0.6); vertical-align: middle; white-space: nowrap; background: #0d1117; color: #e6edf3; }
tr:hover td { background: rgba(255,255,255,0.02); }
tr.row-sold td { opacity: 0.38; }
tr.row-kept td { background: rgba(232,184,75,0.04); }

.p-name { font-weight: 600; color: var(--text); font-size: 14px; }
.p-rank { font-family: 'DM Mono', monospace; color: var(--muted); font-size: 11px; }
.pos-pill { display: inline-block; padding: 1px 5px; border-radius: 3px; font-size: 10px; font-family: 'DM Mono', monospace; font-weight: 500; margin: 1px 0; }
.pos-C  { background: rgba(74,158,218,0.15); color: #4a9eda; }
.pos-SS { background: rgba(226,123,62,0.15); color: #e27b3e; }
.pos-OF { background: rgba(63,182,139,0.15); color: #3fb68b; }
.pos-1B { background: rgba(155,111,201,0.15); color: #9b6fc9; }
.pos-2B { background: rgba(201,169,110,0.15); color: #c9a96e; }
.pos-3B { background: rgba(91,191,207,0.15); color: #5bbfcf; }
.pos-SP { background: rgba(224,85,85,0.15); color: #e05555; }
.pos-RP { background: rgba(212,133,79,0.15); color: #d4854f; }
.pos-UT { background: rgba(136,136,136,0.1); color: #999; }

.mono { font-family: 'DM Mono', monospace; }
.gold { color: var(--accent); }
.green { color: var(--green); }
.red { color: var(--danger); }
.blue { color: var(--blue); }

.status-chip { font-size: 10px; padding: 2px 8px; border-radius: 10px; font-weight: 600; font-family: 'DM Mono', monospace; white-space: nowrap; }
.chip-avail { background: rgba(63,182,139,0.12); color: var(--green); }
.chip-kept  { background: rgba(232,184,75,0.12); color: var(--accent); }
.chip-sold  { background: rgba(224,85,85,0.1); color: var(--danger); }

/* INLINE ASSIGN */
.assign-cell { display: flex; gap: 5px; align-items: center; min-width: 280px; }
.asel { background: var(--surface2); border: 1px solid var(--border); color: var(--text); padding: 4px 7px; border-radius: 4px; font-size: 11px; outline: none; flex: 1; max-width: 130px; }
.ainp { background: var(--surface2); border: 1px solid var(--border); color: var(--text); padding: 4px 7px; border-radius: 4px; font-size: 11px; width: 52px; outline: none; font-family: 'DM Mono', monospace; }
.asel:focus, .ainp:focus { border-color: var(--accent); }
.ickept { accent-color: var(--accent); width: 13px; height: 13px; cursor: pointer; }

/* PAGINATION */
.pagination { display: flex; gap: 6px; justify-content: center; align-items: center; margin-top: 14px; flex-wrap: wrap; }
.pg-btn { background: var(--surface2); border: 1px solid var(--border); color: var(--muted); padding: 5px 11px; border-radius: 5px; cursor: pointer; font-size: 12px; font-family: 'DM Mono', monospace; transition: all 0.12s; }
.pg-btn:hover { border-color: var(--accent); color: var(--accent); }
.pg-btn.active { border-color: var(--accent); color: var(--accent); background: rgba(232,184,75,0.08); }
.pg-info { color: var(--muted); font-size: 11px; font-family: 'DM Mono', monospace; padding: 0 6px; }

/* TEAMS */
.teams-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 16px; }
.team-card { background: #161b22; border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
.team-hdr { background: #1e2530; border-bottom: 1px solid var(--border); padding: 10px 14px; }
.team-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 6px; }
.team-name-edit { background: transparent; border: none; color: var(--text); font-family: 'Bebas Neue', sans-serif; font-size: 20px; letter-spacing: 2px; outline: none; width: 200px; cursor: pointer; }
.team-name-edit:focus { background: var(--surface); border-radius: 3px; padding: 0 4px; cursor: text; }
.team-budget-info { text-align: right; }
.budget-remaining { font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 1px; }
.budget-sub { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--muted); }
.budget-bar-wrap { height: 3px; background: var(--border); border-radius: 2px; overflow: hidden; }
.budget-bar-fill { height: 100%; background: var(--accent); transition: width 0.3s; border-radius: 2px; }
.budget-bar-fill.over { background: var(--danger); }
.team-roster { padding: 6px 0; min-height: 40px; }
.roster-item { display: flex; align-items: center; padding: 4px 10px; gap: 0; }
.roster-item:hover { background: rgba(255,255,255,0.02); }
.ri-left { display: flex; align-items: center; gap: 6px; flex: 1; min-width: 0; }
.ri-name { font-size: 12px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.ri-meta { font-size: 10px; color: var(--muted); font-family: 'DM Mono', monospace; flex-shrink: 0; }
.ri-right { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
.ri-price { font-family: 'DM Mono', monospace; font-size: 12px; color: var(--accent); font-weight: 500; }
.ri-kept-badge { font-size: 9px; background: rgba(232,184,75,0.12); color: var(--accent); padding: 1px 5px; border-radius: 3px; font-family: 'DM Mono', monospace; }
.ri-rm { background: none; border: none; color: var(--muted); cursor: pointer; padding: 2px 4px; border-radius: 3px; font-size: 13px; line-height: 1; }
.ri-rm:hover { color: var(--danger); background: rgba(224,85,85,0.1); }
.empty-msg { color: var(--muted); font-size: 11px; text-align: center; padding: 14px; font-style: italic; }

.no-results { text-align: center; padding: 40px; color: var(--muted); font-size: 14px; }

/* MODAL */
.overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.65); z-index: 200; align-items: center; justify-content: center; }
.overlay.open { display: flex; }
.modal { background: #161b22; border: 1px solid var(--border); border-radius: 12px; padding: 28px; min-width: 380px; max-width: 500px; width: 90%; box-shadow: 0 24px 80px rgba(0,0,0,0.5); }
.modal h3 { font-family: 'Bebas Neue', sans-serif; font-size: 24px; letter-spacing: 1.5px; margin-bottom: 4px; }
.modal-sub { color: var(--muted); font-size: 12px; margin-bottom: 22px; font-family: 'DM Mono', monospace; }
.frow { margin-bottom: 16px; }
.frow label { display: block; font-size: 10px; text-transform: uppercase; letter-spacing: 0.8px; color: var(--muted); margin-bottom: 6px; font-family: 'DM Mono', monospace; }
.frow select, .frow input[type=number] { width: 100%; background: var(--surface2); border: 1px solid var(--border); color: var(--text); padding: 10px 12px; border-radius: 6px; font-size: 14px; outline: none; font-family: 'DM Sans', sans-serif; }
.frow select:focus, .frow input:focus { border-color: var(--accent); }
.frow-check { display: flex; align-items: center; gap: 8px; font-size: 13px; }
.frow-check input { accent-color: var(--accent); width: 15px; height: 15px; }
.modal-acts { display: flex; gap: 10px; justify-content: flex-end; margin-top: 22px; }
.modal-info { background: rgba(232,184,75,0.06); border: 1px solid rgba(232,184,75,0.2); border-radius: 6px; padding: 8px 12px; font-size: 11px; color: var(--muted); font-family: 'DM Mono', monospace; margin-bottom: 16px; }

/* SALARY PROGRESSION INFO */
.prog-note { background: var(--surface2); border: 1px solid var(--border); border-radius: 6px; padding: 10px 14px; font-size: 11px; color: var(--muted); font-family: 'DM Mono', monospace; margin-bottom: 16px; line-height: 1.7; }
.prog-note strong { color: var(--text); }

.divider { height: 1px; background: var(--border); margin: 8px 0; }

/* TEAM META PILLS */
.team-meta-row { display: flex; gap: 8px; margin-top: 8px; flex-wrap: wrap; }
.team-meta-pill { background: var(--bg); border: 1px solid var(--border); border-radius: 6px; padding: 5px 10px; display: flex; flex-direction: column; gap: 1px; flex: 1; min-width: 70px; }
.team-meta-pill.highlight-pill { border-color: rgba(232,184,75,0.3); background: rgba(232,184,75,0.04); }
.tmp-label { font-size: 8px; text-transform: uppercase; letter-spacing: 0.8px; color: var(--muted); font-family: 'DM Mono', monospace; white-space: normal; word-break: break-word; }
.tmp-val { font-family: 'Bebas Neue', sans-serif; font-size: 18px; letter-spacing: 1px; line-height: 1.1; }
.tmp-max { font-size: 12px; color: var(--muted); }
.tmp-open { font-size: 9px; font-family: 'DM Mono', monospace; white-space: nowrap; }

/* ROSTER SECTIONS */
.roster-section-hdr { display: flex; justify-content: space-between; align-items: center; padding: 6px 14px; background: rgba(255,255,255,0.02); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
.roster-section-hdr.milb { background: rgba(63,182,139,0.04); }
.rsh-label { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px; color: var(--muted); font-family: 'DM Mono', monospace; }
.roster-section-hdr.milb .rsh-label { color: var(--green); }
.rsh-count { font-size: 10px; color: var(--muted); font-family: 'DM Mono', monospace; }

/* TARGET */
.target-sel { background: var(--surface2); border: 1px solid var(--border); color: var(--muted); padding: 3px 6px; border-radius: 4px; font-size: 11px; outline: none; cursor: pointer; font-family: 'DM Mono', monospace; min-width: 90px; }
.target-sel:focus { border-color: var(--accent); }
tr.row-target td { background: rgba(63,182,139,0.06) !important; }
tr.row-target td:first-child { border-left: 3px solid var(--green); }
tr.row-dnd td { background: rgba(224,85,85,0.05) !important; }
tr.row-dnd td:first-child { border-left: 3px solid var(--danger); }
tr.row-dnd { opacity: 0.5; }

/* ROSTER SLOT LABELS */
.ri-slot { font-family: 'DM Mono', monospace; font-size: 9px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; min-width: 30px; text-align: right; padding-right: 8px; flex-shrink: 0; }
.ri-slot.milb-slot { color: var(--green); font-size: 11px; font-weight: 700; letter-spacing: 0; }
.roster-item.empty-slot { opacity: 0.3; }
.slot-empty-label { font-size: 11px; color: var(--muted); font-style: italic; font-family: 'DM Mono', monospace; }
.roster-sub-hdr { font-family: 'DM Mono', monospace; font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; color: var(--subtle); padding: 6px 14px 3px; background: rgba(255,255,255,0.01); border-top: 1px solid rgba(42,52,65,0.5); }
.milb-prank { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--accent); background: rgba(232,184,75,0.1); padding: 1px 5px; border-radius: 3px; margin-left: 5px; }
.pos-change-sel { background: var(--surface2); border: 1px solid var(--accent); color: var(--accent); padding: 1px 4px; border-radius: 3px; font-size: 10px; font-family: 'DM Mono', monospace; font-weight: 600; cursor: pointer; outline: none; }
.btn-move-bench, .btn-move-starter { border: none; border-radius: 3px; font-size: 10px; font-family: 'DM Mono', monospace; font-weight: 600; cursor: pointer; padding: 2px 6px; transition: all 0.12s; white-space: nowrap; }
.btn-move-bench   { background: rgba(125,133,144,0.12); color: var(--muted); }
.btn-move-bench:hover   { background: rgba(125,133,144,0.25); color: var(--text); }
.btn-move-starter { background: rgba(63,182,139,0.12); color: var(--green); }
.btn-move-starter:hover { background: rgba(63,182,139,0.25); color: var(--green); }

/* PROSPECT TABLE */
.stats-group-hit { color: #4a9eda !important; }
.stats-group-pit { color: #e05555 !important; }
.level-pill { display: inline-block; padding: 1px 6px; border-radius: 3px; font-size: 10px; font-family: 'DM Mono', monospace; font-weight: 500; }
.lv-Majors { background: rgba(232,184,75,0.15); color: var(--accent); }
.lv-AAA    { background: rgba(63,182,139,0.15); color: var(--green); }
.lv-AA     { background: rgba(74,158,218,0.15); color: var(--blue); }
.lv-Aplus  { background: rgba(155,111,201,0.15); color: #9b6fc9; }
.lv-A      { background: rgba(136,136,136,0.12); color: #aaa; }
.lv-Rookie { background: rgba(212,133,79,0.12); color: #d4854f; }
.stat-line { font-family: 'DM Mono', monospace; font-size: 11px; white-space: nowrap; }
.stat-na   { color: var(--subtle); font-size: 11px; font-family: 'DM Mono', monospace; }
.chip-drafted { background: rgba(74,158,218,0.12); color: var(--blue); }
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--subtle); }

/* MY TEAM TAB */
.mt-plus-inp { background: var(--surface2); border: 1px solid var(--border); color: var(--accent); padding: 3px 6px; border-radius: 4px; font-size: 11px; width: 44px; outline: none; font-family: 'DM Mono', monospace; text-align: center; }
.mt-plus-inp:focus { border-color: var(--accent); }
.mt-note-inp { background: transparent; border: none; border-bottom: 1px solid transparent; color: var(--muted); padding: 2px 4px; font-size: 11px; width: 100%; outline: none; font-family: 'DM Sans', sans-serif; transition: border-color 0.15s; }
.mt-note-inp:focus { border-bottom-color: var(--accent); background: var(--surface2); border-radius: 3px 3px 0 0; color: var(--text); }
.mt-salary { font-family: 'DM Mono', monospace; font-size: 12px; color: var(--muted); }
.mt-salary27 { font-family: 'DM Mono', monospace; font-size: 12px; color: var(--accent); font-weight: 600; }
.mt-keeper-chk { accent-color: var(--accent); width: 13px; height: 13px; cursor: pointer; }
.mt-empty-slot td { opacity: 0.3; font-style: italic; font-size: 11px; color: var(--muted); font-family: 'DM Mono', monospace; }
@media (max-width: 900px) { .myteam-grid { grid-template-columns: 1fr !important; } }

/* ── MOBILE / IPHONE ── */
@media (max-width: 768px) {

  /* Header: stack logo above scrollable tabs */
  .header {
    flex-direction: column;
    height: auto;
    padding: 0;
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .logo {
    padding: 10px 16px;
    border-right: none;
    border-bottom: 1px solid var(--border);
    font-size: 20px;
    margin-right: 0;
    justify-content: center;
  }
  .tabs {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    width: 100%;
    border-bottom: 1px solid var(--border);
  }
  .tabs::-webkit-scrollbar { display: none; }
  .tab {
    padding: 0 14px;
    font-size: 11px;
    white-space: nowrap;
    height: 40px;
  }

  /* Panels */
  .panel { padding: 12px; }

  /* Stat cards: smaller, 2-up */
  .stat-row { gap: 8px; }
  .stat-card { min-width: calc(50% - 8px); padding: 8px 12px; flex: 1 1 calc(50% - 8px); }
  .stat-val { font-size: 20px; }

  /* Toolbar: vertical stack */
  .toolbar { flex-direction: column; align-items: stretch; gap: 8px; }
  .toolbar .search-wrap { width: 100%; }
  .toolbar .search-wrap input { width: 100%; }
  .toolbar select.fsel { width: 100%; }
  .toolbar .btn { width: 100%; text-align: center; }
  .toolbar .count-pill { text-align: center; }

  /* Tables: horizontal scroll with hint shadow */
  .tbl-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: 6px;
  }
  table { font-size: 12px; min-width: 600px; }
  th, td { padding: 7px 9px; white-space: nowrap; }

  /* Modal: full-width on mobile */
  .modal {
    min-width: unset;
    width: 95%;
    padding: 20px 16px;
    max-height: 90vh;
    overflow-y: auto;
  }

  /* Teams grid: single column */
  .teams-grid { grid-template-columns: 1fr; gap: 12px; }

  /* Team card roster items: tighter */
  .roster-item { padding: 4px 8px; }
  .ri-name { font-size: 11px; }
  .ri-meta { display: none; } /* hide MLB team abbr to save space */
  .ri-price { font-size: 11px; }
  .btn-move-bench, .btn-move-starter { font-size: 9px; padding: 2px 4px; }

  /* Team header meta pills: 2-up grid */
  .team-meta-row { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
  .team-meta-pill { min-width: unset; }
  .team-name-edit { font-size: 16px; width: 160px; }
