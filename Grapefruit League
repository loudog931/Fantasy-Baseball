// ======================================================
// STATE
// ======================================================
let players = [];    // working copy with { ...raw, status:'available'|'kept'|'sold', teamId:null, auctionPrice:null, isKeeper:false }
let prospects = [];  // minor league draft pool
let teams = [];      // { id, name }
let sortKey = 'rank';
let sortDir = 1;
let page = 1;
let pSortKey = 'rank';
let pSortDir = 1;
let pPage = 1;
const PER_PAGE = 50;
let pendingPlayerId = null;

// ======================================================
// INIT
// ======================================================
function init() {
  const saved = localStorage.getItem('gfl_state');
  if (saved) {
    try {
      const s = JSON.parse(saved);
      players   = s.players   || [];
      teams     = s.teams     || [];
      prospects = s.prospects || [];
      // Merge in any missing raw players
      const existingIds = new Set(players.map(p => p.id));
      RAW_PLAYERS.forEach(rp => { if (!existingIds.has(rp.id)) players.push({ ...rp }); });
      // Merge in any missing raw prospects
      const existingPIds = new Set(prospects.map(p => p.id));
      RAW_PROSPECTS.forEach(rp => { if (!existingPIds.has(rp.id)) prospects.push({ ...rp }); });
    } catch(e) { buildFresh(); }
  } else { buildFresh(); }
  buildTeamFilter();
  buildProspectTeamFilter();
  buildTeamSelects();
  updateStats();
  renderTable();
  renderTeams();
}

function buildFresh() {
  players   = RAW_PLAYERS.map(p => ({ ...p }));
  prospects = RAW_PROSPECTS.map(p => ({ ...p }));
  teams     = TEAM_NAMES.map((name, i) => ({ id: i + 1, name, collapsed: false }));
}

function save() {
  localStorage.setItem('gfl_state', JSON.stringify({ players, teams, prospects }));
}

// ======================================================
// HELPERS
// ======================================================
function getTeamRoster(teamId) {
  return players.filter(p => p.teamId === teamId);
}

function teamSpent(teamId) {
  return getTeamRoster(teamId)
    .filter(p => !p.isKeeper)
    .reduce((s, p) => s + (p.auctionPrice || 0), 0);
}

function teamKeeperCost(teamId) {
  return getTeamRoster(teamId)
    .filter(p => p.isKeeper)
    .reduce((s, p) => s + (p.auctionPrice || 0), 0);
}

function teamTotalCommitted(teamId) {
  // Only ML players (salary > 0) count against the $260 budget
  return getTeamRoster(teamId).filter(p => (p.auctionPrice||0) > 0).reduce((s, p) => s + (p.auctionPrice || 0), 0);
}

function teamBudgetLeft(teamId) {
  return BUDGET - teamTotalCommitted(teamId);
}

function posPills(posStr) {
  return posStr.split(',').map(p => {
    const cls = ['C','SS','OF','1B','2B','3B','SP','RP','UT'].includes(p.trim()) ? 'pos-' + p.trim() : 'pos-UT';
    return `<span class="pos-pill ${cls}">${p.trim()}</span>`;
  }).join('');
}

function posMatchesFilter(posStr, filter) {
  if (!filter) return true;
  return posStr.split(',').some(p => p.trim() === filter);
}

function buildTeamFilter() {
  const sel = document.getElementById('teamF');
  sel.innerHTML = '<option value="">All Teams</option>';
  teams.forEach(t => {
    const o = document.createElement('option');
    o.value = t.id;
    o.textContent = t.name;
    sel.appendChild(o);
  });
}

function buildTeamSelects() {
  [document.getElementById('mTeam')].forEach(sel => {
    sel.innerHTML = '<option value="">— Select team —</option>';
    teams.forEach(t => {
      const o = document.createElement('option');
      o.value = t.id;
      const spent = teamTotalCommitted(t.id);
      o.textContent = `${t.name}  ($${BUDGET - spent} left)`;
      sel.appendChild(o);
    });
  });
}

