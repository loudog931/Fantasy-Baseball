  // Teams stats
  const totalSpent = players.reduce((s, p) => s + (p.auctionPrice || 0), 0);
  const avgSpent   = assigned > 0 ? (totalSpent / assigned).toFixed(1) : '0';
  const maxPrice   = assigned > 0 ? Math.max(...players.filter(p=>p.auctionPrice).map(p=>p.auctionPrice)) : 0;
