const ML_MAX   = 23;
const MILB_MAX = 15;
const LINEUP_SLOTS  = ['C','1B','2B','3B','SS','OF','OF','OF','UT','SP','SP','SP','SP','SP','RP','RP'];
const LINEUP_LABELS = ['C','1B','2B','3B','SS','OF1','OF2','OF3','UT','SP1','SP2','SP3','SP4','SP5','RP1','RP2'];

function renderTeams() {
  const grid = document.getElementById('teamsGrid');
  grid.innerHTML = teams.map(t => renderTeamCard(t)).join('');
}

function countSPs(roster) {
  return roster.filter(p => p.pos.split(',').some(x => x.trim() === 'SP')).length;
}

function playerEligiblePositions(p) {
  return (p.eligiblePos || p.pos).split(',').map(x => x.trim());
}

function canFillSlot(slot, player) {
  const eligible = playerEligiblePositions(player);
  if (slot === 'UT') return eligible.some(p => ['C','1B','2B','3B','SS','OF','DH'].includes(p));
  return eligible.includes(slot);
}

function assignPlayersToSlots(mlRoster) {
  const assigned = new Array(LINEUP_SLOTS.length).fill(null);
  const used     = new Set();
  for (let si = 0; si < LINEUP_SLOTS.length; si++) {
    const slot = LINEUP_SLOTS[si];
    const idx  = mlRoster.findIndex((p, i) => !used.has(i) && canFillSlot(slot, p));
    if (idx !== -1) { assigned[si] = mlRoster[idx]; used.add(idx); }
  }
  const bench = mlRoster.filter((_, i) => !used.has(i))
                         .sort((a,b) => (b.auctionPrice||0) - (a.auctionPrice||0));
  return { assigned, bench };
}

function changePlayerPos(pid, newPos, teamId) {
  const p = players.find(x => x.id === pid);
  if (!p) return;
  p.pos = newPos;
  save();
  renderTeams();
}

function renderRosterSlotItem(p, slotLabel, teamId) {
  const eligible   = playerEligiblePositions(p);
  const showChange = eligible.length > 1;
  const posDisplay = showChange
    ? `<select class="pos-change-sel" title="Change active position"
         onchange="changePlayerPos('${p.id}', this.value, ${teamId})">
         ${eligible.map(pos => `<option value="${pos}"${pos===p.pos?' selected':''}>${pos}</option>`).join('')}
       </select>`
    : posPills(p.pos);
  const benchBtn = p.onBench
    ? `<button class="btn-move-starter" onclick="toggleBench('${p.id}')" title="Move to starters">▲ Start</button>`
    : `<button class="btn-move-bench"   onclick="toggleBench('${p.id}')" title="Move to bench">▽ Bench</button>`;
  return `<div class="roster-item">
    <div class="ri-slot">${slotLabel}</div>
    <div class="ri-left">
      ${posDisplay}
      <span class="ri-name">${p.name}</span>
      <span class="ri-meta">${p.mlbTeam}</span>
    </div>
    <div class="ri-right">
      ${p.isKeeper ? '<span class="ri-kept-badge">KEPT</span>' : ''}
      <span class="ri-price">${(p.auctionPrice||0) > 0 ? '\$'+p.auctionPrice : ''}</span>
      ${benchBtn}
      <button class="ri-rm" onclick="unassign('${p.id}')" title="Remove">✕</button>
    </div>
  </div>`;
}

function toggleBench(pid) {
  const p = players.find(x => x.id === pid);
  if (!p) return;
  p.onBench = !p.onBench;
  save();
  renderTeams();
}

function renderEmptySlot(slotLabel, slotName) {
  return `<div class="roster-item empty-slot">
    <div class="ri-slot">${slotLabel}</div>
    <div class="ri-left"><span class="slot-empty-label">${slotName} — empty</span></div>
  </div>`;
}

function renderTeamCard(t) {
  const roster   = getTeamRoster(t.id);
  const mlRoster = roster.filter(p => (p.auctionPrice||0) > 0)
                         .sort((a,b) => (b.auctionPrice||0) - (a.auctionPrice||0));

  // Sort minors by prospect rank
  const minors = roster.filter(p => (p.auctionPrice||0) === 0);
  const prospRankMap = {};
  if (typeof prospects !== 'undefined') {
    prospects.forEach(pr => { prospRankMap[pr.name.toLowerCase().trim()] = pr.rank; });
  }
  minors.sort((a,b) => {
    const ra = prospRankMap[a.name.toLowerCase().trim()] || 9999;
    const rb = prospRankMap[b.name.toLowerCase().trim()] || 9999;
    return ra - rb;
  });

  const mlSalary  = mlRoster.reduce((s,p) => s + (p.auctionPrice||0), 0);
  const mlOpen    = ML_MAX   - mlRoster.length;
  const milbOpen  = MILB_MAX - minors.length;
  const spCount   = countSPs(mlRoster);
  const left      = BUDGET - mlSalary;
  const pct       = Math.min(100, (mlSalary / BUDGET) * 100);
  const over      = mlSalary > BUDGET;
  const leftColor = over ? 'red' : left < 30 ? 'gold' : 'green';
  const avgPerSlot = mlOpen > 0 ? (left / mlOpen).toFixed(1) : '—';
  const avgColor   = mlOpen === 0 ? 'var(--muted)' : parseFloat(avgPerSlot) < 5 ? 'var(--danger)' : 'var(--text)';
  const slotColor  = mlOpen <= 2 ? 'var(--danger)' : mlOpen <= 5 ? 'var(--accent)' : 'var(--green)';
  const milbColor  = milbOpen <= 0 ? 'var(--danger)' : milbOpen <= 2 ? 'var(--accent)' : 'var(--muted)';
  const spColor    = spCount >= 9 ? 'var(--danger)' : spCount >= 7 ? 'var(--accent)' : 'var(--muted)';

  // --- ML section split into Offense + Pitching ---
  let mlHtml = '';
  if (mlRoster.length === 0) {
    mlHtml = '<div class="empty-msg">No ML players assigned yet.</div>';
  } else {
    const offRoster  = mlRoster.filter(p => !p.pos.split(',').some(x => ['SP','RP'].includes(x.trim())));
    const pitRoster  = mlRoster.filter(p => p.pos.split(',').some(x => ['SP','RP'].includes(x.trim())));

    // Split into starters vs bench using the onBench flag
    const offStarters = offRoster.filter(p => !p.onBench);
    const pitStarters = pitRoster.filter(p => !p.onBench);
    const bench       = mlRoster.filter(p =>  p.onBench);

    // ── OFFENSE STARTERS ──
    const offSlots  = ['C','1B','2B','3B','SS','OF','OF','OF','UT'];
    const offLabels = ['C','1B','2B','3B','SS','OF1','OF2','OF3','UT'];
    const offAssigned = new Array(offSlots.length).fill(null);
    const offUsed = new Set();
    for (let si = 0; si < offSlots.length; si++) {
      const idx = offStarters.findIndex((p,i) => !offUsed.has(i) && canFillSlot(offSlots[si], p));
      if (idx !== -1) { offAssigned[si] = offStarters[idx]; offUsed.add(idx); }
    }
    const offOverflow = offStarters.filter((_, i) => !offUsed.has(i));

    mlHtml += '<div class="roster-sub-hdr" style="color:var(--blue)">🏏 OFFENSE</div>';
    if (offStarters.length === 0) {
      mlHtml += '<div class="empty-msg" style="font-size:11px;padding:8px 14px">No offense starters.</div>';
    } else {
      offAssigned.forEach((p, i) => {
        mlHtml += p ? renderRosterSlotItem(p, offLabels[i], t.id) : renderEmptySlot(offLabels[i], offSlots[i]);
      });
    }

    // ── PITCHING STARTERS ──
    const pitSlots  = ['SP','SP','SP','SP','SP','RP','RP'];
    const pitLabels = ['SP1','SP2','SP3','SP4','SP5','RP1','RP2'];
    const pitAssigned = new Array(pitSlots.length).fill(null);
    const pitUsed = new Set();
    for (let si = 0; si < pitSlots.length; si++) {
      const idx = pitStarters.findIndex((p,i) => !pitUsed.has(i) && canFillSlot(pitSlots[si], p));
      if (idx !== -1) { pitAssigned[si] = pitStarters[idx]; pitUsed.add(idx); }
    }
    const pitOverflow = pitStarters.filter((_, i) => !pitUsed.has(i));

    mlHtml += '<div class="roster-sub-hdr" style="color:#e05555">⚾ PITCHING</div>';
    if (pitStarters.length === 0) {
      mlHtml += '<div class="empty-msg" style="font-size:11px;padding:8px 14px">No pitching starters.</div>';
    } else {
      pitAssigned.forEach((p, i) => {
        mlHtml += p ? renderRosterSlotItem(p, pitLabels[i], t.id) : renderEmptySlot(pitLabels[i], pitSlots[i]);
      });
    }

    // ── COMBINED BENCH (manually benched + overflow from both groups) ──
    const allBench = [...bench, ...offOverflow, ...pitOverflow];
    mlHtml += `<div class="roster-sub-hdr" style="color:var(--muted)">📋 BENCH <span style="font-weight:400;font-size:9px;opacity:0.7">(${allBench.length})</span></div>`;
    if (allBench.length === 0) {
      mlHtml += '<div class="empty-msg" style="font-size:11px;padding:8px 14px">No bench players.</div>';
    } else {
      allBench.forEach((p, i) => { mlHtml += renderRosterSlotItem(p, 'BN'+(i+1), t.id); });
    }
  }

  // --- MiLB section ---
  let milbHtml = '';
  const draftedProspects = typeof prospects !== 'undefined'
    ? prospects.filter(pr => pr.teamId === t.id)
    : [];
  const prospByName = {};
  draftedProspects.forEach(pr => { prospByName[pr.name.toLowerCase().trim()] = pr; });

  for (let i = 0; i < MILB_MAX; i++) {
    const p = minors[i];
    if (p) {
      const pr   = prospByName[p.name.toLowerCase().trim()];
      const pRnk = pr ? `<span class="milb-prank">#${pr.rank}</span>` : '';
      milbHtml += `<div class="roster-item">
        <div class="ri-slot milb-slot">${i+1}</div>
        <div class="ri-left">
          ${posPills(p.pos)}
          <span class="ri-name">${p.name}</span>
          <span class="ri-meta">${p.mlbTeam}</span>
          ${pRnk}
        </div>
        <div class="ri-right">
          ${p.isKeeper ? '<span class="ri-kept-badge">KEPT</span>' : ''}
          <button class="ri-rm" onclick="unassign('${p.id}')" title="Remove">✕</button>
        </div>
      </div>`;
    } else {
      milbHtml += `<div class="roster-item empty-slot">
        <div class="ri-slot milb-slot">${i+1}</div>
        <div class="ri-left"><span class="slot-empty-label">Open MiLB slot</span></div>
      </div>`;
    }
  }

  return `<div class="team-card" id="tc-${t.id}">
    <div class="team-hdr">
      <div class="team-top">
        <input class="team-name-edit" value="${t.name.replace(/"/g,'&quot;')}"
          onblur="renameTeam(${t.id}, this.value)"
          onkeydown="if(event.key==='Enter')this.blur()">
        <div class="team-budget-info">
          <div class="budget-remaining ${leftColor}">${over ? '⚠ OVER' : '\$'+left+' left'}</div>
          <div class="budget-sub">\$${mlSalary} / \$${BUDGET} committed</div>
        </div>
      </div>
      <div class="team-meta-row">
        <div class="team-meta-pill">
          <span class="tmp-label">ML Slots</span>
          <span class="tmp-val" style="color:${slotColor}">${mlRoster.length}<span class="tmp-max">/${ML_MAX}</span></span>
          <span class="tmp-open" style="color:${slotColor}">${mlOpen} open</span>
        </div>
        <div class="team-meta-pill">
          <span class="tmp-label">MiLB Slots</span>
          <span class="tmp-val" style="color:${milbColor}">${minors.length}<span class="tmp-max">/${MILB_MAX}</span></span>
          <span class="tmp-open" style="color:${milbColor}">${milbOpen > 0 ? milbOpen+' open' : 'FULL'}</span>
        </div>
        <div class="team-meta-pill">
          <span class="tmp-label">SPs</span>
          <span class="tmp-val" style="color:${spColor}">${spCount}<span class="tmp-max">/9</span></span>
          <span class="tmp-open" style="color:${spColor}">${9-spCount > 0 ? (9-spCount)+' avail' : 'MAX'}</span>
        </div>
        <div class="team-meta-pill highlight-pill">
          <span class="tmp-label">Avg $/Open Slot</span>
          <span class="tmp-val" style="color:${avgColor}">${mlOpen > 0 ? '\$'+avgPerSlot : '—'}</span>
          <span class="tmp-open" style="color:var(--muted)">${mlOpen} slot${mlOpen!==1?'s':''}</span>
        </div>
      </div>
      <div class="budget-bar-wrap" style="margin-top:8px">
        <div class="budget-bar-fill ${over?'over':''}" style="width:${pct}%"></div>
      </div>
    </div>

    <div class="roster-section-hdr">
      <span class="rsh-label">⚾ Major League Roster</span>
      <span class="rsh-count">${mlRoster.length} / ${ML_MAX} · \$${mlSalary}</span>
    </div>
    <div class="team-roster">${mlHtml}</div>

    <div class="roster-section-hdr milb">
      <span class="rsh-label">🌱 Minor League Taxi Squad</span>
      <span class="rsh-count">${minors.length} / ${MILB_MAX} · by prospect rank</span>
    </div>
    <div class="team-roster">${milbHtml}</div>
  </div>`;
}
