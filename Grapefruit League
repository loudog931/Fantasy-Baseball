function getProspectsFiltered() {
  const q    = document.getElementById('psrch').value.toLowerCase();
  const pos  = document.getElementById('pposF').value;
  const lev  = document.getElementById('plevF').value;
  const stat = document.getElementById('pstatF').value;
  const tid  = document.getElementById('pteamF').value;
  const tag  = document.getElementById('ptagF').value;

  return prospects.filter(p => {
    if (q && !p.name.toLowerCase().includes(q) && !p.mlbOrg.toLowerCase().includes(q)) return false;
    if (pos && p.pos !== pos) return false;
    if (lev && p.level !== lev) return false;
    if (stat && p.status !== stat) return false;
    if (tid && String(p.teamId) !== String(tid)) return false;
    if (tag === 'any' && !p.target) return false;
    if (tag && tag !== 'any' && (p.target || '') !== tag) return false;
    return true;
  });
}

function sortProspects(key) {
  if (pSortKey === key) pSortDir *= -1; else { pSortKey = key; pSortDir = 1; }
  document.querySelectorAll('[id^="pth-"]').forEach(th => th.classList.remove('sort-asc','sort-desc'));
  const th = document.getElementById('pth-' + key);
  if (th) th.classList.add(pSortDir === 1 ? 'sort-asc' : 'sort-desc');
  pPage = 1;
  renderProspects();
}

function levelPill(lv) {
  const cls = lv === 'Majors' ? 'lv-Majors' : lv === 'AAA' ? 'lv-AAA' : lv === 'AA' ? 'lv-AA' : lv === 'A+' ? 'lv-Aplus' : lv === 'A' ? 'lv-A' : 'lv-Rookie';
  return `<span class="level-pill ${cls}">${lv}</span>`;
}

function renderProspects() {
  updateProspectStats();
  let data = getProspectsFiltered();
  data.sort((a, b) => {
    let av = a[pSortKey], bv = b[pSortKey];
    if (av == null) av = pSortDir === 1 ? 9999 : -9999;
    if (bv == null) bv = pSortDir === 1 ? 9999 : -9999;
    if (typeof av === 'string') av = av.toLowerCase();
    if (typeof bv === 'string') bv = bv.toLowerCase();
    if (av < bv) return -1 * pSortDir;
    if (av > bv) return  1 * pSortDir;
    return 0;
  });

  const total   = data.length;
  const maxPage = Math.max(1, Math.ceil(total / PER_PAGE));
  if (pPage > maxPage) pPage = maxPage;
  const sliced  = data.slice((pPage - 1) * PER_PAGE, pPage * PER_PAGE);

  document.getElementById('pCountPill').textContent = `${total} prospect${total !== 1 ? 's' : ''}`;

  const tbody = document.getElementById('ptbody');
  if (!sliced.length) {
    tbody.innerHTML = `<tr><td colspan="14" class="no-results">No prospects match the current filters.</td></tr>`;
    renderProspectPagination(0, maxPage);
    return;
  }

  tbody.innerHTML = sliced.map(p => {
    const isPitcher = p.pos === 'P';
    const rowCls = [
      p.status === 'drafted' ? 'row-sold' : '',
      p.target === 'Target'  ? 'row-target' : '',
      p.target === 'DND'     ? 'row-dnd'    : '',
    ].filter(Boolean).join(' ');

    const hitStats = isPitcher
      ? `<span class="stat-na">—</span>`
      : `<span class="stat-line">${p.avg} / ${p.obp} / ${p.slg} / <strong>${p.ops}</strong></span>`;

    const hit2Stats = isPitcher
      ? `<span class="stat-na">—</span>`
      : `<span class="stat-line">${p.hr} HR · ${p.sb} SB</span>`;

    const pitStats = !isPitcher
      ? `<span class="stat-na">—</span>`
      : `<span class="stat-line">${p.era} ERA / ${p.whip} WHIP / ${p.k9} K9 / ${p.bb9} BB9</span>`;

    const assignedTeam = p.teamId ? teams.find(t => t.id === p.teamId) : null;
    const statusChip = p.status === 'available'
      ? '<span class="status-chip chip-avail">Available</span>'
      : `<span class="status-chip chip-drafted">Drafted</span>`;

    const assignCell = assignedTeam
      ? `<span style="font-size:11px;color:var(--muted);font-family:'DM Mono',monospace;">${assignedTeam.name}</span>
         ${p.draftRound ? `<span style="font-size:10px;color:var(--blue);margin-left:4px;font-family:'DM Mono',monospace;">Rd ${p.draftRound}</span>` : ''}`
      : buildProspectInlineAssign(p.id);

    const actionBtn = p.teamId
      ? `<button class="btn btn-danger btn-sm" onclick="unassignProspect('${p.id}')">✕</button>`
      : '';

    return `<tr class="${rowCls}" data-pid="${p.id}">
      <td class="mono" style="font-size:11px;color:var(--muted)">#${p.rank}</td>
      <td><span class="p-name">${p.name}</span></td>
      <td><span class="pos-pill pos-${p.pos === 'DH' ? 'UT' : p.pos === 'P' ? 'SP' : p.pos}">${p.pos}</span></td>
      <td class="mono" style="font-size:11px;color:var(--muted)">${p.mlbOrg}</td>
      <td class="mono" style="font-size:12px">${p.age}</td>
      <td class="mono" style="font-size:12px;color:var(--accent)">${p.eta}</td>
      <td>${levelPill(p.level)}</td>
      <td>${hitStats}</td>
      <td>${hit2Stats}</td>
      <td>${pitStats}</td>
      <td>${buildProspectTargetCell(p.id, p.target)}</td>
      <td>${statusChip}</td>
      <td>${assignCell}</td>
      <td>${actionBtn}</td>
    </tr>`;
  }).join('');

  // attach inline assign handlers
  sliced.filter(p => !p.teamId).forEach(p => {
    const btn = document.getElementById(`pqbtn-${p.id}`);
    if (btn) btn.onclick = () => quickAssignProspect(p.id);
  });

  renderProspectPagination(total, maxPage);
}

function buildProspectInlineAssign(pid) {
  const teamOpts = teams.map(t => {
    const drafted = prospects.filter(p => p.teamId === t.id).length;
    const open = 15 - drafted;
    return `<option value="${t.id}">${t.name} (${open} open)</option>`;
  }).join('');
  return `<div class="assign-cell">
    <select class="asel" id="pqs-${pid}">
      <option value="">Team…</option>
      ${teamOpts}
    </select>
    <input class="ainp" type="number" id="pqr-${pid}" min="1" max="15" placeholder="Rd" title="Draft Round">
    <button id="pqbtn-${pid}" class="btn btn-green btn-sm">✓</button>
  </div>`;
}

function quickAssignProspect(pid) {
  const teamId = document.getElementById(`pqs-${pid}`)?.value;
  const round  = document.getElementById(`pqr-${pid}`)?.value;
  if (!teamId) { alert('Please select a team.'); return; }
  assignProspect(pid, parseInt(teamId), round ? parseInt(round) : null);
}

function assignProspect(pid, teamId, draftRound) {
  const p = prospects.find(x => x.id === pid);
  if (!p) return;
  p.teamId     = teamId;
  p.draftRound = draftRound;
  p.status     = 'drafted';
  save();
  updateProspectStats();
  renderProspects();
}

function unassignProspect(pid) {
  const p = prospects.find(x => x.id === pid);
  if (!p) return;
  if (!confirm(`Remove ${p.name} from their team?`)) return;
  p.teamId     = null;
  p.draftRound = null;
  p.status     = 'available';
  save();
  updateProspectStats();
  renderProspects();
}

function buildProspectTargetCell(pid, current) {
  const val  = current || '';
  const opts = [
    ['', '—'],
    ['Target', '🎯 Target'],
    ['DND', '🚫 DND'],
  ].map(([v, label]) => `<option value="${v}" ${val===v?'selected':''}>${label}</option>`).join('');
  return `<select class="target-sel" id="ptsel-${pid}" onchange="setProspectTarget('${pid}', this.value)">${opts}</select>`;
}

function setProspectTarget(pid, value) {
  const p = prospects.find(x => x.id === pid);
  if (!p) return;
  p.target = value || null;
  save();
  const row = document.querySelector(`tr[data-pid="${pid}"]`);
  if (row) {
    row.classList.toggle('row-target', value === 'Target');
    row.classList.toggle('row-dnd',    value === 'DND');
  }
  updateProspectStats();
}

function renderProspectPagination(total, maxPage) {
  const pgn = document.getElementById('ppgn');
  if (maxPage <= 1) { pgn.innerHTML = ''; return; }
  let html = '';
  if (pPage > 1) html += `<button class="pg-btn" onclick="goProspectPage(${pPage-1})">‹</button>`;
  for (let i = 1; i <= maxPage; i++) {
    if (i === 1 || i === maxPage || Math.abs(i - pPage) <= 2) {
      html += `<button class="pg-btn ${i===pPage?'active':''}" onclick="goProspectPage(${i})">${i}</button>`;
    } else if (Math.abs(i - pPage) === 3) {
      html += `<span class="pg-info">…</span>`;
    }
  }
  if (pPage < maxPage) html += `<button class="pg-btn" onclick="goProspectPage(${pPage+1})">›</button>`;
  html += `<span class="pg-info">${(pPage-1)*PER_PAGE+1}–${Math.min(pPage*PER_PAGE,total)} of ${total}</span>`;
  pgn.innerHTML = html;
}

function goProspectPage(n) { pPage = n; renderProspects(); window.scrollTo(0,0); }

// close modal on overlay click
document.getElementById('modal').addEventListener('click', e => { if(e.target === document.getElementById('modal')) closeModal(); });
// close on Escape
document.addEventListener('keydown', e => { if(e.key === 'Escape') closeModal(); });

// ======================================================
// MY TEAM — "Up And At Them"
// ======================================================
const MY_TEAM_NAME = 'Up And At Them';
const OFFENSE_POS  = ['C','1B','2B','3B','SS','OF','DH','UT'];
const PITCH_POS    = ['SP','RP'];
const MILB_SLOTS   = 7; // BN17–BN23

function getMyTeam() {
  return teams.find(t => t.name.toLowerCase() === MY_TEAM_NAME.toLowerCase());
}

// Keeper salary progression per the league rules
function keeperPlus(p) {
  // If already marked keeper, show +$1/+$3/+$5 based on keeperYear stored (default +$5 if unknown)
  if (!p.isKeeper) return 0;
  const yr = p.keeperYear || 3;
  if (yr === 1) return 1;
  if (yr === 2) return 3;
  return 5;
}

function salary2027(p) {
  const plus = parseInt(p.keeperPlus27 ?? keeperPlus(p));
  return (p.auctionPrice || 0) + plus;
}

function isPitcher(p) {
  return p.pos.split(',').some(x => PITCH_POS.includes(x.trim()));
}

function isOffense(p) {
  return !isPitcher(p);
}

function isMiLB(p) {
  return (p.auctionPrice || 0) === 0;
}

function renderMyTeam() {
  const t = getMyTeam();
  if (!t) {
    document.getElementById('panel-myteam').innerHTML = '<div class="no-results">Team "Up And At Them" not found.</div>';
    return;
  }

  const roster    = getTeamRoster(t.id);
  const mlRoster  = roster.filter(p => !isMiLB(p));
  const milbPlayers = roster.filter(p => isMiLB(p));

  const offense = mlRoster.filter(isOffense);
  const pitching = mlRoster.filter(isPitcher);

  // render a section's tbody rows
  function renderRows(players, slotPrefix, isMilbSection) {
    let html = '';
    const slotNames = isMilbSection
      ? ['BN 17','BN 18','BN 19','BN 20','BN 21','BN 22','BN 23']
      : null;
    const maxSlots = isMilbSection ? MILB_SLOTS : players.length;

    for (let i = 0; i < Math.max(maxSlots, players.length); i++) {
      const p = players[i];
      if (!p) {
        const slotLabel = isMilbSection ? (slotNames[i] || `BN ${17+i}`) : '—';
        html += `<tr class="mt-empty-slot">
          <td class="mono" style="font-size:10px;color:var(--muted)">${slotLabel}</td>
          <td colspan="${isMilbSection ? 7 : 6}" style="color:var(--muted);font-style:italic">— empty —</td>
        </tr>`;
        continue;
      }
      const slotLabel = isMilbSection ? (slotNames[i] || `BN ${17+i}`) : p.pos.split(',')[0].trim();
      const plus      = p.keeperPlus27 !== undefined ? p.keeperPlus27 : keeperPlus(p);
      const sal27     = (p.auctionPrice || 0) + parseInt(plus || 0);
      const salColor  = sal27 > (p.auctionPrice || 0) ? 'color:var(--accent)' : 'color:var(--muted)';

      html += `<tr data-pid="${p.id}">
        <td><span class="pos-pill pos-${['C','SS','OF','1B','2B','3B','SP','RP','UT'].includes(slotLabel)?slotLabel:'UT'}">${slotLabel}</span></td>
        <td class="p-name" style="font-size:13px">${p.name}
          ${p.isKeeper ? '<span class="ri-kept-badge" style="margin-left:6px">KEPT</span>' : ''}
        </td>
        <td class="mt-salary">$${p.auctionPrice || 0}</td>
        <td>
          <input class="mt-plus-inp" type="number" id="mt-plus-${p.id}" value="${plus}"
            min="0" max="10" title="Salary increase for 2027"
            onchange="setMyTeamPlus('${p.id}', this.value)">
        </td>
        <td class="mt-salary27" style="${salColor}">$${sal27}</td>
        <td style="text-align:center">
          <input type="checkbox" class="mt-keeper-chk" id="mt-kp-${p.id}"
            ${p.isKeeper ? 'checked' : ''}
            onchange="setMyTeamKeeper('${p.id}', this.checked)">
        </td>
        <td>
          <input class="mt-note-inp" type="text" id="mt-note-${p.id}"
            value="${(p.myTeamNote || '').replace(/"/g,'&quot;')}"
            placeholder="add note…"
            onblur="setMyTeamNote('${p.id}', this.value)">
        </td>
        <td>
          <button class="ri-rm" onclick="unassign('${p.id}')" title="Remove">✕</button>
        </td>
      </tr>`;
    }
    return html;
  }

  // Offense totals
  const off26 = offense.reduce((s,p) => s + (p.auctionPrice||0), 0);
  const off27 = offense.reduce((s,p) => s + salary2027(p), 0);
  // Pitching totals
  const pit26 = pitching.reduce((s,p) => s + (p.auctionPrice||0), 0);
  const pit27 = pitching.reduce((s,p) => s + salary2027(p), 0);
  // MiLB totals
  const milb26 = milbPlayers.reduce((s,p) => s + (p.auctionPrice||0), 0);
  const milb27 = milbPlayers.reduce((s,p) => s + salary2027(p), 0);
  // Grand totals
  const grand26 = off26 + pit26 + milb26;
  const grand27 = off27 + pit27 + milb27;
  const avail26 = BUDGET - grand26;
  const avail27 = BUDGET - grand27;
  const openSlots = (ML_MAX - mlRoster.length) + Math.max(0, MILB_SLOTS - milbPlayers.length);
  const fpp27 = openSlots > 0 ? (avail27 / openSlots).toFixed(1) : '—';

  document.getElementById('mt-off-body').innerHTML  = renderRows(offense, 'off', false);
  document.getElementById('mt-pit-body').innerHTML  = renderRows(pitching, 'pit', false);
  document.getElementById('mt-milb-body').innerHTML = renderRows(milbPlayers, 'bn', true);

  document.getElementById('mt-off-total26').textContent  = `$${off26}`;
  document.getElementById('mt-off-total27').textContent  = `$${off27}`;
  document.getElementById('mt-pit-total26').textContent  = `$${pit26}`;
  document.getElementById('mt-pit-total27').textContent  = `$${pit27}`;
  document.getElementById('mt-milb-total26').textContent = `$${milb26}`;
  document.getElementById('mt-milb-total27').textContent = `$${milb27}`;

  document.getElementById('mt-off-summary').textContent  = `${offense.length} players · $${off26} → $${off27}`;
  document.getElementById('mt-pit-summary').textContent  = `${pitching.length} players · $${pit26} → $${pit27}`;
  document.getElementById('mt-milb-summary').textContent = `${milbPlayers.length}/${MILB_SLOTS} slots · $${milb26} → $${milb27}`;

  document.getElementById('mt-grand-26').textContent = `$${grand26}`;
  document.getElementById('mt-grand-27').textContent = `$${grand27}`;
  const a26El = document.getElementById('mt-avail-26');
  a26El.textContent = `$${avail26}`;
  a26El.style.color = avail26 < 0 ? 'var(--danger)' : avail26 < 30 ? 'var(--accent)' : 'var(--green)';
  const a27El = document.getElementById('mt-avail-27');
  a27El.textContent = avail27 < 0 ? `-$${Math.abs(avail27)}` : `$${avail27}`;
  a27El.style.color = avail27 < 0 ? 'var(--danger)' : avail27 < 30 ? 'var(--accent)' : 'var(--green)';
  document.getElementById('mt-fpp-27').textContent = openSlots > 0 ? `$${fpp27}` : '—';

  // Stats bar
  document.getElementById('myteamStats').innerHTML = `
    <div class="stat-card highlight"><div class="stat-label">ML Roster</div><div class="stat-val gold">${mlRoster.length}/${ML_MAX}</div></div>
    <div class="stat-card"><div class="stat-label">MiLB Roster</div><div class="stat-val blue">${milbPlayers.length}/${MILB_SLOTS}</div></div>
    <div class="stat-card"><div class="stat-label">2026 Salary</div><div class="stat-val gold">$${grand26}</div></div>
    <div class="stat-card"><div class="stat-label">2026 Remaining</div><div class="stat-val ${avail26<0?'red':avail26<30?'gold':'green'}">${avail26<0?'−$'+Math.abs(avail26):'$'+avail26}</div></div>
    <div class="stat-card"><div class="stat-label">2027 Proj. Salary</div><div class="stat-val">${grand27>0?'$'+grand27:'—'}</div></div>
    <div class="stat-card"><div class="stat-label">2027 Remaining</div><div class="stat-val ${avail27<0?'red':avail27<30?'gold':'green'}">${avail27<0?'−$'+Math.abs(avail27):(grand27>0?'$'+avail27:'—')}</div></div>
    <div class="stat-card"><div class="stat-label">Keepers</div><div class="stat-val">${roster.filter(p=>p.isKeeper).length}</div></div>
  `;
}

function setMyTeamPlus(pid, val) {
  const p = players.find(x => x.id === pid);
  if (!p) return;
  p.keeperPlus27 = parseInt(val) || 0;
  save();
  renderMyTeam();
}

function setMyTeamKeeper(pid, checked) {
  const p = players.find(x => x.id === pid);
  if (!p) return;
  p.isKeeper = checked;
  p.status   = checked ? 'kept' : (p.teamId ? 'sold' : 'available');
  if (checked && p.keeperPlus27 === undefined) {
    p.keeperPlus27 = 5; // default +$5
  }
  save();
  renderMyTeam();
  updateStats();
}

function setMyTeamNote(pid, val) {
  const p = players.find(x => x.id === pid);
  if (!p) return;
  p.myTeamNote = val.trim();
  save();
}

init();
</script>
