      <div class="stat-label">Available</div>
      <div class="stat-val green">${available}</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Drafted</div>
      <div class="stat-val blue">${drafted}</div>
    </div>
    <div class="stat-card" style="border-color:rgba(63,182,139,0.3)">
      <div class="stat-label">🎯 Targets</div>
      <div class="stat-val green">${targets}</div>
    </div>
    <div class="stat-card" style="border-color:rgba(224,85,85,0.2)">
      <div class="stat-label">🚫 DND</div>
      <div class="stat-val red">${dnds}</div>
