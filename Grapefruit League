// ======================================================
// TABLE
// ======================================================
function getFiltered() {
  const q      = document.getElementById('srch').value.toLowerCase();
  const pos    = document.getElementById('posF').value;
  const stat   = document.getElementById('statF').value;
  const tid    = document.getElementById('teamF').value;
  const tgt    = document.getElementById('targetF').value;

  return players.filter(p => {
    if (q && !p.name.toLowerCase().includes(q) && !p.mlbTeam.toLowerCase().includes(q)) return false;
    if (!posMatchesFilter(p.pos, pos)) return false;
    if (stat && p.status !== stat) return false;
    if (tid && String(p.teamId) !== String(tid)) return false;
    if (tgt === 'any' && !p.target) return false;
    if (tgt && tgt !== 'any' && (p.target || '') !== tgt) return false;
    return true;
  });
}

function sortCol(key) {
  if (sortKey === key) sortDir *= -1; else { sortKey = key; sortDir = 1; }
  document.querySelectorAll('th').forEach(th => { th.classList.remove('sort-asc','sort-desc'); });
  const th = document.getElementById('th-' + key);
  if (th) th.classList.add(sortDir === 1 ? 'sort-asc' : 'sort-desc');
  page = 1;
  renderTable();
}

function renderTable() {
  let data = getFiltered();
  data.sort((a, b) => {
    let av = a[sortKey], bv = b[sortKey];
    if (typeof av === 'string') av = av.toLowerCase();
    if (typeof bv === 'string') bv = bv.toLowerCase();
    if (av < bv) return -1 * sortDir;
    if (av > bv) return  1 * sortDir;
    return 0;
  });

  const total = data.length;
  const maxPage = Math.max(1, Math.ceil(total / PER_PAGE));
  if (page > maxPage) page = maxPage;
  const sliced = data.slice((page - 1) * PER_PAGE, page * PER_PAGE);

  document.getElementById('countPill').textContent = `${total} player${total !== 1 ? 's' : ''}`;

  const tbody = document.getElementById('tbody');
  if (!sliced.length) {
    tbody.innerHTML = `<tr><td colspan="11" class="no-results">No players match the current filters.</td></tr>`;
    renderPagination(0, maxPage);
    return;
  }

  tbody.innerHTML = sliced.map(p => {
    const rowCls = [
      p.status === 'sold' ? 'row-sold' : p.status === 'kept' ? 'row-kept' : '',
      p.target === 'Target' ? 'row-target' : '',
      p.target === 'DND'    ? 'row-dnd'    : '',
    ].filter(Boolean).join(' ');
    const statusChip = p.status === 'available'
      ? '<span class="status-chip chip-avail">Available</span>'
      : p.status === 'kept'
      ? '<span class="status-chip chip-kept">⭐ Kept</span>'
      : '<span class="status-chip chip-sold">Sold</span>';

    const assignedTeam = p.teamId ? teams.find(t => t.id === p.teamId) : null;
    const assignCell = assignedTeam
      ? `<span style="font-size:11px;color:var(--muted);font-family:'DM Mono',monospace;">${assignedTeam.name}</span>
         <span style="font-family:'DM Mono',monospace;font-size:12px;color:var(--accent);margin-left:4px;">$${p.auctionPrice}</span>
         ${p.isKeeper ? '<span style="font-size:9px;background:rgba(232,184,75,0.12);color:var(--accent);padding:1px 5px;border-radius:3px;margin-left:4px;">KEPT</span>' : ''}
        `
      : buildInlineAssign(p.id);

    const actionBtn = p.teamId
      ? `<button class="btn btn-ghost btn-sm" onclick="openModal('${p.id}')">✏</button>
         <button class="btn btn-danger btn-sm" onclick="unassign('${p.id}')">✕</button>`
      : `<button class="btn btn-primary btn-sm" onclick="openModal('${p.id}')">Assign</button>`;

    return `<tr class="${rowCls}" data-id="${p.id}">
      <td class="mono muted" style="font-size:11px;color:var(--muted)">#${p.rank}</td>
      <td><span class="p-name">${p.name}</span></td>
      <td>${posPills(p.pos)}</td>
      <td class="mono" style="font-size:11px;color:var(--muted)">${p.mlbTeam}</td>
      <td class="mono" style="font-size:12px">${p.age}</td>
      <td class="mono gold" style="font-size:12px">${p.fpts}</td>
      <td class="mono" style="font-size:12px">${p.fpg}</td>
      <td class="mono" style="font-size:12px;color:var(--muted)">$${p.salary}</td>
      <td>${buildTargetCell(p.id, p.target)}</td>
      <td>${statusChip}</td>
      <td>${assignCell}</td>
      <td>${actionBtn}</td>
    </tr>`;
  }).join('');

  // attach inline assign handlers
  sliced.filter(p => !p.teamId).forEach(p => {
    const btn = document.getElementById(`qbtn-${p.id}`);
    if (btn) btn.onclick = () => quickAssign(p.id);
  });

  renderPagination(total, maxPage);
  updateStats();
}

function buildTargetCell(pid, current) {
  const val = current || '';
  const opts = [
    ['', '—'],
    ['Target', '🎯 Target'],
    ['DND', '🚫 DND'],
  ].map(([v, label]) => `<option value="${v}" ${val===v?'selected':''}>${label}</option>`).join('');
  return `<select class="target-sel" id="tsel-${pid}" onchange="setTarget('${pid}', this.value)">${opts}</select>`;
}

function setTarget(pid, value) {
  const p = players.find(x => x.id === pid);
  if (!p) return;
  p.target = value || null;
  save();
  // re-render just the cell's row highlight without full re-render for snappiness
  const row = document.querySelector(`tr[data-id="${pid}"]`);
  if (row) {
    row.classList.toggle('row-target', value === 'Target');
    row.classList.toggle('row-dnd',    value === 'DND');
  }
  updateStats();
}

function buildInlineAssign(pid) {
  const teamOpts = teams.map(t => {
    const left = teamBudgetLeft(t.id);
    return `<option value="${t.id}">${t.name} ($${left})</option>`;
  }).join('');
  return `<div class="assign-cell">
    <select class="asel" id="qs-${pid}">
      <option value="">Team…</option>
      ${teamOpts}
    </select>
    <input class="ainp" type="number" id="qp-${pid}" min="1" max="260" placeholder="$">
    <input type="checkbox" class="ickept" id="qk-${pid}" title="Keeper">
    <button id="qbtn-${pid}" class="btn btn-green btn-sm">✓</button>
  </div>`;
}

function quickAssign(pid) {
  const teamId = document.getElementById(`qs-${pid}`)?.value;
  const price  = parseInt(document.getElementById(`qp-${pid}`)?.value || '0');
  const kept   = document.getElementById(`qk-${pid}`)?.checked || false;
  if (!teamId) { alert('Please select a team.'); return; }
  if (!price || price < 1) { alert('Please enter an auction price ($1 minimum).'); return; }
  assignPlayer(pid, parseInt(teamId), price, kept);
}

function renderPagination(total, maxPage) {
  const pgn = document.getElementById('pgn');
  if (maxPage <= 1) { pgn.innerHTML = ''; return; }
  let html = '';
  if (page > 1) html += `<button class="pg-btn" onclick="goPage(${page-1})">‹</button>`;
  for (let i = 1; i <= maxPage; i++) {
    if (i === 1 || i === maxPage || Math.abs(i - page) <= 2) {
      html += `<button class="pg-btn ${i===page?'active':''}" onclick="goPage(${i})">${i}</button>`;
    } else if (Math.abs(i - page) === 3) {
      html += `<span class="pg-info">…</span>`;
    }
  }
  if (page < maxPage) html += `<button class="pg-btn" onclick="goPage(${page+1})">›</button>`;
  html += `<span class="pg-info">${(page-1)*PER_PAGE+1}–${Math.min(page*PER_PAGE,total)} of ${total}</span>`;
  pgn.innerHTML = html;
}

function goPage(n) { page = n; renderTable(); window.scrollTo(0,0); }

