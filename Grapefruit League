function openModal(pid) {
  pendingPlayerId = pid;
  const p = players.find(x => x.id === pid);
  if (!p) return;
  document.getElementById('mTitle').textContent = 'Assign Player';
  document.getElementById('mSub').textContent   = `${p.name} · ${p.pos} · ${p.mlbTeam} · Rank #${p.rank}`;
  document.getElementById('mInfo').textContent  = `FPts: ${p.fpts} · FP/G: ${p.fpg} · Fantrax Salary: $${p.salary}`;
  buildTeamSelects();
  document.getElementById('mPrice').value = p.auctionPrice || '';
  document.getElementById('mKept').checked = p.isKeeper || false;
  if (p.teamId) {
    const sel = document.getElementById('mTeam');
    sel.value = p.teamId;
  }
  document.getElementById('modal').classList.add('open');
  document.getElementById('mPrice').focus();
}

function closeModal() {
  document.getElementById('modal').classList.remove('open');
  pendingPlayerId = null;
}

function confirmAssign() {
  const teamId = parseInt(document.getElementById('mTeam').value);
  const price  = parseInt(document.getElementById('mPrice').value || '0');
  const kept   = document.getElementById('mKept').checked;
  if (!teamId) { alert('Please select a team.'); return; }
  if (!price || price < 1) { alert('Please enter an auction price ($1 minimum).'); return; }
  assignPlayer(pendingPlayerId, teamId, price, kept);
  closeModal();
}

function assignPlayer(pid, teamId, price, isKeeper) {
  const p = players.find(x => x.id === pid);
  if (!p) return;
  p.teamId      = teamId;
  p.auctionPrice = price;
  p.isKeeper    = isKeeper;
  p.status      = isKeeper ? 'kept' : 'sold';
  save();
  buildTeamSelects();
  updateStats();
  renderTable();
  renderTeams();
}

function unassign(pid) {
  const p = players.find(x => x.id === pid);
  if (!p) return;
  if (!confirm(`Remove ${p.name} from their team?`)) return;
  p.teamId       = null;
  p.auctionPrice = null;
  p.isKeeper     = false;
  p.status       = 'available';
  save();
  buildTeamSelects();
  updateStats();
  renderTable();
  renderTeams();
}

